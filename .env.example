APP_HOST=0.0.0.0
APP_PORT=8080
APP_VERSION=0.2.0
OFFLINE_MODE=true
ALLOW_MODEL_AUTO_DOWNLOAD=false
ALLOW_DATASET_DOWNLOAD=false
RUN_FULL_TRAIN=false
MAX_TRAIN_ROUNDS=3
MAX_TRAIN_MINUTES=90
MOCK_ALLOW_EXPECTED_TEXT=false

MODEL_CLASSIFY_PATH=models/classify/classifier.pt
MODEL_DETECT_PATH=models/detect/yolo11n.pt
MODEL_OCR_PATH=models/ocr/paddleocr

CLASSIFY_BACKEND=fallback
DETECT_BACKEND=fallback
OCR_BACKEND=fallback

DETECT_SCORE_THRESHOLD=0.25
DETECT_MAX_TARGETS=50
DETECT_EMPTY_FALLBACK=false
DETECT_DEVICE=cpu
DETECT_IMGSZ=640

OCR_USE_ANGLE_CLS=true
OCR_LANG=ch
OCR_DET_MODEL_DIR=models/ocr/paddleocr/det
OCR_REC_MODEL_DIR=models/ocr/paddleocr/rec
OCR_CLS_MODEL_DIR=models/ocr/paddleocr/cls
OCR_MAX_TEXT_LENGTH=128

IMAGE_DOWNLOAD_TIMEOUT_SECONDS=5
MAX_IMAGE_SIZE_MB=20

LOG_LEVEL=INFO
LOG_FILE=logs/app.log
